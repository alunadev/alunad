                      "name": "f2num",
                      "fill": "#1a1a1a",
                      "content": "02",
                      "fontFamily": "Gelasio",
                      "fontSize": 32,
                      "fontWeight": "bold"
                    },
                    {
                      "type": "text",
                      "id": "8Fbdp",
                      "name": "f2title",
                      "fill": "#1a1a1a",
                      "content": "Scoring Opacity",
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "semibold"
                    },
                    {
                      "type": "text",
                      "id": "YwHUx",
                      "name": "f2desc",
                      "fill": "#737373",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Users couldn't understand why their players scored specific points, reducing engagement",
