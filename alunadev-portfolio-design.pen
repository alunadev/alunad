        {
          "type": "frame",
          "id": "vGgPY",
          "name": "About the Company",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 16,
          "children": [
            {
              "type": "text",
              "id": "8LSu8",
              "name": "aboutLabel",
              "fill": "#999999",
              "content": "ABOUT THE COMPANY",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal",
              "letterSpacing": 1.5
            },
            {
              "type": "text",
              "id": "ZSW8j",
              "name": "aboutText",
              "fill": "#1a1a1a",
              "textGrowth": "fixed-width",
              "width": 700,
              "content": "LALIGA is the top professional football league in Spain, reaching over 2.8 billion fans worldwide through digital products, broadcasting, and live events. The organization has been transforming its digital ecosystem to engage fans beyond match day.",
              "lineHeight": 1.7,
              "fontFamily": "Inter",
              "fontSize": 16,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "4LSci",
          "name": "About the Product",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 16,
          "children": [
            {
              "type": "text",
              "id": "WZkkS",
              "name": "prodLabel",
              "fill": "#999999",
              "content": "ABOUT THE PRODUCT",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal",
              "letterSpacing": 1.5
            },
            {
              "type": "text",
              "id": "dSoRK",
              "name": "prodText",
              "fill": "#1a1a1a",
              "textGrowth": "fixed-width",
              "width": 700,
              "content": "LALIGA Fantasy is a free-to-play fantasy football platform where fans create dream teams, compete in leagues with friends, and earn points based on real match performance. With over 3 million active users per season, it is one of the league's most engaging digital products.",
              "lineHeight": 1.7,
              "fontFamily": "Inter",
              "fontSize": 16,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "q6rKS",
          "name": "The Challenge",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 24,
          "children": [
            {
              "type": "text",
              "id": "QbQzO",
              "name": "challLabel",
              "fill": "#999999",
              "content": "THE CHALLENGE",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal",
              "letterSpacing": 1.5
            },
            {
              "type": "text",
              "id": "Gpk2q",
              "name": "challText",
              "fill": "#1a1a1a",
              "textGrowth": "fixed-width",
              "width": 700,
              "content": "User retention was dropping after the first month of each season. Research showed that casual fans found the onboarding complex, the scoring system opaque, and the weekly management loop too demanding. We needed to simplify the core experience without alienating power users who loved the depth.",
              "lineHeight": 1.7,
              "fontFamily": "Inter",
              "fontSize": 16,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "3kgPZ",
              "name": "Research Photos",
              "width": "fill_container",
              "gap": 24,
              "children": [
                {
                  "type": "rectangle",
                  "cornerRadius": 12,
                  "id": "YdxrO",
                  "name": "Research Photo 1",
                  "fill": "#f0f0f0",
                  "width": "fill_container",
                  "height": 300
                },
                {
                  "type": "rectangle",
                  "cornerRadius": 12,
                  "id": "XtOQN",
                  "name": "Research Photo 2",
                  "fill": "#f0f0f0",
                  "width": "fill_container",
                  "height": 300
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "ZBhpO",
          "name": "Research & Discovery",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 32,
          "children": [
            {
              "type": "text",
              "id": "WqtI2",
              "name": "resLabel",
              "fill": "#999999",
              "content": "RESEARCH & DISCOVERY",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal",
              "letterSpacing": 1.5
            },
            {
              "type": "text",
              "id": "w1jfx",
              "name": "resText",
              "fill": "#1a1a1a",
              "textGrowth": "fixed-width",
              "width": 700,
              "content": "We conducted 24 user interviews across three segments: hardcore fantasy players, casual football fans, and lapsed users. Combined with behavioral analytics from Amplitude, we mapped the complete user journey and identified three critical drop-off points.",
              "lineHeight": 1.7,
              "fontFamily": "Inter",
              "fontSize": 16,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "p4iUt",
              "name": "Findings",
              "width": "fill_container",
              "gap": 40,
              "children": [
                {
                  "type": "frame",
                  "id": "Z5qmE",
                  "name": "f1",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 8,
                  "children": [
                    {
                      "type": "text",
                      "id": "TS7tG",
                      "name": "f1num",
                      "fill": "#1a1a1a",
                      "content": "01",
                      "fontFamily": "Gelasio",
                      "fontSize": 32,
                      "fontWeight": "bold"
                    },
                    {
                      "type": "text",
                      "id": "jRMjT",
                      "name": "f1title",
                      "fill": "#1a1a1a",
                      "content": "Complex Onboarding",
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "semibold"
                    },
                    {
                      "type": "text",
                      "id": "kDnfi",
                      "name": "f1desc",
                      "fill": "#737373",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "New users abandoned during team creation due to too many choices and unclear guidance",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
